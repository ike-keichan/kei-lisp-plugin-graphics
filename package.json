{
  "name": "kei-lisp-plugin-graphics",
  "version": "3.0.1",
  "description": "Canvas2D graphics plugin for the kei-lisp interpreter",
  "author": "Keisuke Ikeda",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "lisp",
    "kei-lisp",
    "plugin",
    "graphics",
    "canvas"
  ],
  "homepage": "https://github.com/ike-keichan/kei-lisp-plugin-graphics#readme",
  "bugs": {
    "url": "https://github.com/ike-keichan/kei-lisp-plugin-graphics/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ike-keichan/kei-lisp-plugin-graphics.git"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "lisp/"
  ],
  "scripts": {
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm check && pnpm test",
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "pnpm build && node e2e/run.mjs",
    "screenshot": "pnpm build && node e2e/screenshot.mjs",
    "doc": "typedoc",
    "typecheck": "tsc --noEmit",
    "check": "run-s check:*",
    "check:format": "prettier \"./src/**/*.ts\" \"./examples/**/*.ts\" --check",
    "check:format-config": "prettier \"./*.{js,mjs,json,md}\" \"./docs/**/*.md\" \"./.github/**/*.yml\" \"./configs/**/*.mjs\" \"./e2e/**/*.mjs\" --check",
    "check:knip": "knip",
    "check:lint": "eslint \"./src/**/*.ts\" \"./examples/**/*.ts\"",
    "check:lint-config": "eslint ./*.{js,mjs} \"./configs/**/*.mjs\" \"./e2e/**/*.mjs\"",
    "check:package": "publint && attw --pack .",
    "check:spell": "cspell \"./src/**/*.ts\" \"./examples/**/*.ts\"",
    "check:spell-config": "cspell \"./*.{js,mjs,json,md}\" \"./docs/**/*.md\" \"./.github/**/*.yml\" \"./configs/**/*.mjs\" \"./e2e/**/*.mjs\"",
    "fix": "run-s fix:*",
    "fix:format": "prettier \"./src/**/*.ts\" \"./examples/**/*.ts\" --write",
    "fix:format-config": "prettier \"./*.{js,mjs,json,md}\" \"./docs/**/*.md\" \"./.github/**/*.yml\" \"./configs/**/*.mjs\" \"./e2e/**/*.mjs\" --write",
    "fix:lint": "eslint \"./src/**/*.ts\" \"./examples/**/*.ts\" --fix",
    "fix:lint-config": "eslint ./*.{js,mjs} \"./configs/**/*.mjs\" \"./e2e/**/*.mjs\" --fix"
  },
  "peerDependencies": {
    "kei-lisp": "^3.0.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^10.0.1",
    "@napi-rs/canvas": "^1.0.2",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "cspell": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.8.9",
    "kei-lisp": "^3.0.1",
    "knip": "^6.24.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.3"
}
